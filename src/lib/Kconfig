menu "Libraries"

config RTFRAME_LIB
    bool "Enable optional RTFrame libraries"
    default y
    help
      Master switch for optional RTFrame libraries (log, perf, ringbuffer,
      crc, heatshrink, mathlib, matrix, mavlink_log, console_buffer,
      parameters, sd_bench, tinybson). The hrt library is always compiled
      as it is required by the core runtime.

rsource "hrt/Kconfig"
rsource "log/Kconfig"
rsource "perf/Kconfig"
rsource "ringbuffer/Kconfig"
rsource "crc/Kconfig"
rsource "heatshrink/Kconfig"
rsource "mathlib/Kconfig"
rsource "matrix/Kconfig"
rsource "mavlink_log/Kconfig"
rsource "console_buffer/Kconfig"
rsource "parameters/Kconfig"
rsource "sd_bench/Kconfig"
rsource "tinybson/Kconfig"
rsource "version/Kconfig"
rsource "circuit_breaker/Kconfig"
rsource "atmosphere/Kconfig"
rsource "airspeed/Kconfig"
rsource "geo/Kconfig"
rsource "conversion/Kconfig"
rsource "timesync/Kconfig"
rsource "dataman_client/Kconfig"
rsource "adsb/Kconfig"
rsource "tunes/Kconfig"
rsource "variable_length_ringbuffer/Kconfig"

endmenu # Libraries
